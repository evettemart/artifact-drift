{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/hashicorp-ai-hackathon/repo-summary.schema.json",
  "title": "Hackathon Repo Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "git",
    "counts",
    "languages",
    "top_level_modules",
    "changed_files",
    "signals",
    "verification",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2026-06-18"
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "repo_root", "branch", "base_ref", "head_ref"],
      "properties": {
        "available": { "type": "boolean" },
        "repo_root": { "type": "string" },
        "branch": { "type": "string" },
        "base_ref": { "type": "string" },
        "head_ref": { "type": "string" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_total",
        "files_changed",
        "lines_added",
        "lines_deleted",
        "test_files",
        "docs_files",
        "config_files",
        "prompt_files",
        "notebook_files"
      ],
      "properties": {
        "files_total": { "type": "integer", "minimum": 0 },
        "files_changed": { "type": "integer", "minimum": 0 },
        "lines_added": { "type": "integer", "minimum": 0 },
        "lines_deleted": { "type": "integer", "minimum": 0 },
        "test_files": { "type": "integer", "minimum": 0 },
        "docs_files": { "type": "integer", "minimum": 0 },
        "config_files": { "type": "integer", "minimum": 0 },
        "prompt_files": { "type": "integer", "minimum": 0 },
        "notebook_files": { "type": "integer", "minimum": 0 }
      }
    },
    "languages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["files", "lines"],
        "properties": {
          "files": { "type": "integer", "minimum": 0 },
          "lines": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "top_level_modules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_tests",
        "has_docs",
        "has_prompts",
        "has_notebooks",
        "has_ui_changes",
        "has_infra_changes",
        "has_security_sensitive_changes",
        "likely_primary_work_type"
      ],
      "properties": {
        "has_tests": { "type": "boolean" },
        "has_docs": { "type": "boolean" },
        "has_prompts": { "type": "boolean" },
        "has_notebooks": { "type": "boolean" },
        "has_ui_changes": { "type": "boolean" },
        "has_infra_changes": { "type": "boolean" },
        "has_security_sensitive_changes": { "type": "boolean" },
        "likely_primary_work_type": {
          "type": "string",
          "enum": ["Code", "Prompt pack", "Workflow", "Notebook", "Docs", "Mixed", "Unknown"]
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands_run", "commands_failed", "notes"],
      "properties": {
        "commands_run": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "status", "notes"],
            "properties": {
              "command": { "type": "string" },
              "status": { "type": "string", "enum": ["passed", "failed", "not-run"] },
              "notes": { "type": "string" }
            }
          }
        },
        "commands_failed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
