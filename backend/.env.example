# Server
PORT=3001
NODE_ENV=development
DEMO_MODE=false

# AWS (live mode) — single region inventory scan. Configurable; defaults to
# us-east-1 when unset. Change this to target a different region.
AWS_REGION=us-east-1
# Standard AWS credential chain is used (AWS_PROFILE, AWS_ACCESS_KEY_ID/SECRET,
# SSO, container/instance roles). With no credentials, live mode falls back to
# the mock inventory in examples/aws-mock-inventory.json.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# LLM reasoning — Bob gateway (Anthropic-compatible).
LLM_PROVIDER=bob
# Paste your Bob API key here (keep this file out of version control):
BOB_API_KEY=
# Bob gateway base URL (Anthropic-compatible endpoint):
BOB_BASE_URL=

# Optional model override (defaults to claude-3-5