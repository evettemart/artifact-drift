# Server
PORT=3001
NODE_ENV=development
DEMO_MODE=true

# AWS (live mode) — single region inventory scan for now
# AWS_REGION=us-east-1
# Standard AWS credential chain is used (AWS_PROFILE, AWS_ACCESS_KEY_ID/SECRET,
# SSO, container/instance roles). With no credentials, live mode falls back to
# the mock inventory in examples/aws-mock-inventory.json.

# LLM reasoning (optional). Choose ONE provider:
#   LLM_PROVIDER=anthropic | bob   (unset = auto-detect from whichever key exists)
#
# Option A — Anthropic directly:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_BASE_URL=                 # optional override
#
# Option B — Bob gateway (Anthropic-compatible):
# LLM_PROVIDER=bob
# BOB_API_KEY=your_key_here
# BOB_BASE_URL=https://your-bob-gateway/anthropic
#
# Optional model override (defaults to claude-3-5-sonnet-20241022)
# LLM_MODEL=claude-3-5-sonnet-20241022
